# ============================================================================
# buckets Server Configuration
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Listening address and port
HOST=0.0.0.0
PORT=8080

# ---------------------------------------------------------------------------
# Database (MySQL 8.0+)
# ---------------------------------------------------------------------------
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:root@localhost:3306/buckets
# Maximum database connections in the pool (min: 2)
DB_MAX_CONN=20

# ---------------------------------------------------------------------------
# Security — Secret Keys (CRITICAL for production!)
# ---------------------------------------------------------------------------
# HMAC signing key for access tokens. Must be a 64-char hex string.
# If not set, a hardcoded default is used (with error log) — OK for dev, NOT for production.
# Generate one: openssl rand -hex 32
SECRET_KEY=

# Signing key for JWT refresh tokens. Must be a 64-char hex string.
# If not set, a hardcoded default is used (with error log) — OK for dev, NOT for production.
# Generate one: openssl rand -hex 32
REFRESH_TOKEN_KEY=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated allowed origins. Empty = allow all (dev mode).
CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Super Admin
# ---------------------------------------------------------------------------
# Comma-separated user IDs that have web admin privileges.
# Default seed user (admin@buckets.local) has ID 1.
SUPER_ADMIN_IDS=1

# ---------------------------------------------------------------------------
# Seed User
# ---------------------------------------------------------------------------
# Password for the default admin seed user (admin@buckets.local).
# Used by migration to create the initial admin user with argon2-hashed password.
# If not set, defaults to "buckets".
ADMIN_PASSWORD=buckets

# ---------------------------------------------------------------------------
# Rate Limiting (gateway upload endpoints)
# ---------------------------------------------------------------------------
# Set to false to disable all rate limiting
RATE_LIMIT_ENABLED=true
# Token bucket: max requests per second per user
RATE_LIMIT_RPS=2.0
# Token bucket: max burst capacity
RATE_LIMIT_BURST=10.0
# Max concurrent active upload tasks per user
RATE_LIMIT_MAX_CONCURRENT=5
# Max new upload tasks per user per day
RATE_LIMIT_DAILY_QUOTA=50

# ---------------------------------------------------------------------------
# Chunk Upload
# ---------------------------------------------------------------------------
# Maximum allowed chunk size in bytes (default: 256 MiB)
# Clients can request smaller chunks but not larger.
MAX_CHUNK_SIZE=268435456

# ---------------------------------------------------------------------------
# File Extension Validation
# ---------------------------------------------------------------------------
# Set to "true" or "1" to enable strict extension check.
# When enabled: only allowed extensions pass, blocked ones (.exe, .js, etc.) are rejected.
# When disabled (default): all file types are accepted (private storage scenario).
STRICT_EXTENSION_CHECK=false

# ---------------------------------------------------------------------------
# Storage — Object & Staging Directories
# ---------------------------------------------------------------------------
# Root directory for stored object files (created on startup if missing).
STORAGE_DIR=data/objects
# Root directory for chunk staging files during upload (created on startup if missing).
STAGING_DIR=data/staging

# ---------------------------------------------------------------------------
# Logging (tracing-subscriber EnvFilter)
# ---------------------------------------------------------------------------
# Levels: error, warn, info, debug, trace
# Examples:
#   RUST_LOG=info
#   RUST_LOG=buckets_srv=debug
#   RUST_LOG=info,buckets_srv::gateway=debug
RUST_LOG=info

# ---------------------------------------------------------------------------
# CLI-specific (for buckets-cli)
# ---------------------------------------------------------------------------
# Timeout for individual chunk upload requests in seconds (default: 1800 = 30 min)
CHUNK_UPLOAD_TIMEOUT_SECS=1800
