{
  "name": "@chihqiang/buckets",
  "version": "0.1.0",
  "description": "Buckets JavaScript SDK - file upload & management for Buckets server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "buckets",
    "file-upload",
    "tus",
    "chunk-upload",
    "sdk"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@types/spark-md5": "^3.0.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
